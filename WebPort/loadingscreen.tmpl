    <script type="application/javascript">

        /* ══ Spawn bubbles ══ */
        (function () {
            var c = document.getElementById('bubble-container');
            for (var i = 0; i < 25; i++) {
                var b  = document.createElement('div');
                b.className = 'bubble';
                var sz = (Math.random() * 15 + 5) + 'px';
                b.style.width  = sz;
                b.style.height = sz;
                b.style.left   = (Math.random() * 100) + '%';
                b.style.setProperty('--dur',   (Math.random() * 8  + 5)  + 's');
                b.style.setProperty('--delay', '-' + (Math.random() * 10) + 's');
                b.style.setProperty('--sway1', (Math.random() * 40 - 20)  + 'px');
                b.style.setProperty('--sway2', (Math.random() * 40 - 20)  + 'px');
                c.appendChild(b);
            }
        })();

        /* ══ Hide ocean loader when pygame-web is ready ══ */
        function _hideOceanLoader() {
            var fill = document.getElementById('ocean-fill');
            var fish = document.getElementById('bar-fish');
            if (fill) fill.style.width = '100%';
            if (fish) fish.style.left  = '100%';

            var tr = document.getElementById('transfer');
            if (!tr) return;
            setTimeout(function () {
                tr.classList.add('ocean-hidden');
                setTimeout(function () { tr.style.display = 'none'; }, 1100);
            }, 400);
        }

        /* ══ pygame-web lifecycle hooks ══ */
        async function custom_onload(debug_hidden) {
            console.log(__FILE__, "custom_onload");
            // Do NOT hide the ocean loader here — pygbag calls this before
            // the APK download finishes. pg_bar() handles hiding at 100%.
            pyconsole.hidden = debug_hidden;
            system.hidden    = debug_hidden;
            info.hidden      = debug_hidden;
            box.hidden       = debug_hidden;
            var cv = document.getElementById('canvas');
            if (cv && typeof cv.focus === 'function') cv.focus();
        }

        function custom_prerun() {
            console.log(__FILE__, "custom_prerun");
        }

        function custom_postrun() {
            console.log(__FILE__, "custom_postrun");
            window.addEventListener("keydown", function (e) {
                if (["Space","ArrowUp","ArrowDown","ArrowLeft","ArrowRight"].indexOf(e.code) > -1) {
                    if (!python.config.debug)
                        e.preventDefault();
                }
            }, false);
        }

        function debug() {
            python.config.debug = true;
            custom_onload(false);
            Module.PyRun_SimpleString("shell.uptime()");
            window_resize();
        }

        function info_inline(data) { document.getElementById("info").innerHTML = data; }
        function info_online(url)  {
            fetch(url).then(r => r.text()).then(h => { info_inline(h); }).catch(e => { console.warn(e); });
        }
        function frame_online(url) { window.frames["iframe"].location = url; }

    </script>


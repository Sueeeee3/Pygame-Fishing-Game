    <style>
        * { box-sizing: border-box; }

        body {
            font-family: arial;
            margin: 0;
            padding: 0;
            background: #008f89;
        }

        /* ── Canvas — pygame-web owns this ── */
        canvas.emscripten {
            border: 0px none;
            background-color: transparent;
            width: 100%;
            height: 100%;
            z-index: 5;
            padding: 0;
            margin: 0 auto;
            position: absolute;
            top: 0; bottom: 0; left: 0; right: 0;
        }

        #transfer {
            position: fixed;
            inset: 0;
            z-index: 20;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 0; padding: 0;
            background: linear-gradient(180deg,
                #007a74 0%,
                #008f89 25%,
                #009e97 50%,
                #008f89 75%,
                #007a74 100%);
            animation: oceanPulse 7s ease-in-out infinite alternate;
            transition: opacity 1s ease;
            pointer-events: none;
        }
        #transfer.ocean-hidden {
            opacity: 0;
        }

        /* Hide default pygbag children — kept in DOM so pygbag doesn't crash */
        #status, #progress { display: none !important; }

        @keyframes oceanPulse {
            0%   { filter: brightness(0.82); }
            50%  { filter: brightness(1.08); }
            100% { filter: brightness(0.88); }
        }

        /* Progress track */
        .ocean-track {
            width: 480px;
            height: 32px;
            background: rgba(160, 230, 225, 0.35);
            border-radius: 16px;
            border: 2px solid rgba(180, 240, 235, 0.55);
            overflow: visible;
            position: relative;
        }
        .ocean-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #007a74, #00b5ad);
            border-radius: 16px;
            transition: width 0.15s linear;
        }

        /* Fish riding the bar */
        #bar-fish {
            position: absolute;
            top: -48px;
            left: 0%;
            transform: translateX(-50%);
            width: 130px;
            height: 130px;
            object-fit: contain;
            filter: drop-shadow(0 3px 10px rgba(0,0,0,0.5));
            pointer-events: none;
            transition: left 0.15s linear;
        }

        /* Bubbles */
        .ocean-bubbles {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 19;
        }
        .bubble {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle at 32% 30%,
                rgba(180,240,235,0.5),
                rgba(120,210,205,0.04));
            border: 1px solid rgba(160,235,225,0.5);
            opacity: 0;
            animation: bubbleRise var(--dur) ease-in-out var(--delay) infinite;
        }
        @keyframes bubbleRise {
            0%   { bottom: -6%;  opacity: 0;    transform: translateX(0); }
            8%   {               opacity: 0.7; }
            35%  {                              transform: translateX(var(--sway1)); }
            60%  {               opacity: 0.45; transform: translateX(var(--sway2)); }
            85%  {               opacity: 0.25; transform: translateX(var(--sway1)); }
            100% { bottom: 108%; opacity: 0;    transform: translateX(var(--sway2)); }
        }

